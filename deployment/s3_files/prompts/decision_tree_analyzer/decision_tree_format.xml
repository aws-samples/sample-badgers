<!-- You must respond using the format within the <response_format/> xml tags. -->
<!-- BADGERS Schema v1.0 — Part 1 (envelope) + Part 2 (common_spine) + decision_tree -->

<response_format>
    <response analyzer="decision_tree"
             schema_version="1.0"
             page="{PAGE_NUMBER}"
             session_id="{SESSION_ID}">

        <metadata>
            <source_image>{S3_URI_OR_PATH_TO_PAGE_IMAGE}</source_image>
            <analyzer_name>decision_tree</analyzer_name>
            <timestamp>{ISO_8601_TIMESTAMP}</timestamp>
            <page_number>{PAGE_NUMBER_VISIBLE_ON_PAGE_OR_INFERRED}</page_number>
            <examples_count>{NUMBER_OF_EXAMPLE_IMAGES_YOU_WERE_GIVEN}</examples_count>
            <element_count>{NUMBER_OF_DECISION_TREES_DETECTED}</element_count>
            <confidence>{high|medium|low}</confidence>
        </metadata>

        <common_spine element_count="{NUMBER_OF_TEXT_ELEMENTS}">
            <!-- Decision tree title/caption -->
            <element id="elem_001" tag="Caption" order="1" page="{PAGE}">
                <text>{DECISION_TREE_TITLE_OR_CAPTION}</text>
            </element>
            <!-- The tree as a Figure for accessibility -->
            <element id="elem_002" tag="Figure" order="2" page="{PAGE}">
                <alt_text>{NATURAL_LANGUAGE_DESCRIPTION_OF_DECISION_TREE_LOGIC}</alt_text>
                <caption>{CAPTION_TEXT_IF_ANY}</caption>
            </element>
            <!-- Any surrounding body text -->
            <element id="elem_003" tag="P" order="3" page="{PAGE}">
                <text>{BODY_TEXT_ON_PAGE}</text>
            </element>
        </common_spine>

        <topical_analysis>{TOPICS_IDENTIFIED_IN_CONTENT}</topical_analysis>

        <specialized type="decision_tree">
            <elements>
                <element type="decision_tree">
                    <type>Decision Tree</type>
                    <summary>
                        <title>{DECISION_TREE_TITLE_OR_CAPTION}</title>
                        <purpose>{HIGH_LEVEL_PURPOSE_OR_OBJECTIVE}</purpose>
                        <scope>{DOMAIN_OR_CONTEXT}</scope>
                        <tree_type>{BINARY_PROBABILISTIC_CONVERSATIONAL_CLINICAL_PROTOCOL_ETC}</tree_type>
                        <tree_summary>{SUMMARY_OF_TREE_LOGIC}</tree_summary>
                    </summary>
                    <content>
                        <decision_flow>
                            <entry_point>
                                <node_id>start</node_id>
                                <content>{STARTING_CONDITION_OR_INITIAL_STATE}</content>
                            </entry_point>
                            <nodes>
                                <node>
                                    <node_id>{UNIQUE_NODE_ID}</node_id>
                                    <node_type>{decision|action|outcome|condition}</node_type>
                                    <content>{NODE_TEXT}</content>
                                    <branches>
                                        <branch>
                                            <condition>{CONDITION_TEXT}</condition>
                                            <target_node>{TARGET_NODE_ID}</target_node>
                                        </branch>
                                    </branches>
                                </node>
                            </nodes>
                            <outcomes>
                                <outcome>
                                    <node_id>{OUTCOME_NODE_ID}</node_id>
                                    <result>{OUTCOME_TEXT}</result>
                                    <path>{SEQUENCE_OF_DECISIONS_LEADING_HERE}</path>
                                </outcome>
                            </outcomes>
                        </decision_flow>
                    </content>
                    <context>{ROLE_OF_DECISION_TREE_IN_DOCUMENT}</context>
                </element>
            </elements>
        </specialized>

    </response>
</response_format>
