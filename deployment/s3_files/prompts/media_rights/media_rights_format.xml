<!-- You must respond using the format within the <response_format/> xml tags. -->
<!-- BADGERS Schema v1.0 — Part 1 (envelope) + Part 2 (common_spine) + media_rights -->

<response_format>
    <response analyzer="media_rights"
             schema_version="1.0"
             page="{PAGE_NUMBER}"
             session_id="{SESSION_ID}">

        <metadata>
            <source_image>{S3_URI_OR_PATH_TO_PAGE_IMAGE}</source_image>
            <analyzer_name>media_rights</analyzer_name>
            <timestamp>{ISO_8601_TIMESTAMP}</timestamp>
            <page_number>{PAGE_NUMBER_VISIBLE_ON_PAGE_OR_INFERRED}</page_number>
            <examples_count>{NUMBER_OF_EXAMPLE_IMAGES_YOU_WERE_GIVEN}</examples_count>
            <element_count>{NUMBER_OF_CONTRACTS_OR_CONTRACT_PAGES_DETECTED}</element_count>
            <confidence>{high|medium|low}</confidence>
        </metadata>

        <common_spine element_count="{NUMBER_OF_TEXT_ELEMENTS}">
            <!-- Contract title -->
            <element id="elem_001" tag="H1" order="1" page="{PAGE}">
                <text>{DOCUMENT_TITLE}</text>
            </element>
            <!-- Each major section of the contract as a text element -->
            <element id="elem_002" tag="H2" order="2" page="{PAGE}">
                <text>{SECTION_HEADING}</text>
            </element>
            <element id="elem_003" tag="P" order="3" page="{PAGE}">
                <text>{FULL_VERBATIM_SECTION_TEXT}</text>
            </element>
            <!-- Signature blocks -->
            <element id="elem_004" tag="P" order="4" page="{PAGE}">
                <text>{SIGNATURE_BLOCK_TEXT}</text>
            </element>
            <!-- Include ALL visible text in reading order -->
        </common_spine>

        <topical_analysis>{TOPICS_IDENTIFIED_IN_CONTENT}</topical_analysis>

        <specialized type="media_rights">
            <elements>
                <element type="media_rights_contract">
                    <type>Media Rights Contract</type>

                    <contract_identification>
                        <contract_type>{CONTENT_LICENSE|TALENT_AGREEMENT|SYNC_LICENSE|DISTRIBUTION_AGREEMENT|DIGITAL_RIGHTS_UGC|OTHER}</contract_type>
                        <document_title>{EXACT_TITLE_AS_SHOWN}</document_title>
                        <template_notice>{ANY_DISCLAIMER_OR_TEMPLATE_NOTICE_TEXT}</template_notice>
                        <effective_date>{DATE_OR_BLANK_INDICATOR}</effective_date>
                    </contract_identification>

                    <parties>
                        <party>
                            <defined_name>{SHORT_NAME}</defined_name>
                            <legal_name>{FULL_NAME_OR_BLANK}</legal_name>
                            <role>{ROLE_IN_AGREEMENT}</role>
                            <entity_type>{ORGANIZATIONAL_TYPE_OR_BLANK}</entity_type>
                            <jurisdiction>{JURISDICTION_OR_BLANK}</jurisdiction>
                            <principal_office>{ADDRESS_OR_BLANK}</principal_office>
                        </party>
                    </parties>

                    <recitals>
                        <recital>{VERBATIM_TEXT_OF_EACH_WHEREAS_CLAUSE}</recital>
                    </recitals>

                    <defined_terms>
                        <term>
                            <n>{DEFINED_TERM_NAME}</n>
                            <definition>{VERBATIM_DEFINITION}</definition>
                            <section_reference>{WHERE_DEFINED}</section_reference>
                        </term>
                    </defined_terms>

                    <rights_grant>
                        <grant_nature>{EXCLUSIVE|NON_EXCLUSIVE|OTHER}</grant_nature>
                        <transferability>{TRANSFERABLE|NON_TRANSFERABLE|CONDITIONAL}</transferability>
                        <specific_rights>
                            <right>{EACH_SPECIFIC_RIGHT_GRANTED}</right>
                        </specific_rights>
                        <licensed_media>
                            <medium>{EACH_LICENSED_PLATFORM_OR_MEDIA_TYPE}</medium>
                        </licensed_media>
                        <territory>{TERRITORY_SPECIFICATION_OR_BLANK}</territory>
                        <sublicensing>{SUBLICENSING_TERMS}</sublicensing>
                        <reservation_of_rights>{RESERVATION_LANGUAGE}</reservation_of_rights>
                        <holdbacks>
                            <holdback>{EACH_HOLDBACK_PROVISION}</holdback>
                        </holdbacks>
                        <ai_digital_likeness>
                            <provision>{AI_AND_DIGITAL_LIKENESS_TERMS_IF_PRESENT}</provision>
                        </ai_digital_likeness>
                        <merchandising>{MERCHANDISING_RIGHTS_TERMS}</merchandising>
                        <promotional_use>{PROMOTIONAL_USE_ALLOWANCES}</promotional_use>
                    </rights_grant>

                    <financial_terms>
                        <fixed_compensation>
                            <amount>{DOLLAR_AMOUNT_OR_BLANK}</amount>
                            <payment_schedule>{PAYMENT_TIMING}</payment_schedule>
                        </fixed_compensation>
                        <revenue_share>
                            <percentage>{PERCENTAGE_OR_BLANK}</percentage>
                            <revenue_base>{DEFINITION_OF_REVENUE_BASE}</revenue_base>
                            <approved_deductions>{ENUMERATED_DEDUCTIONS}</approved_deductions>
                        </revenue_share>
                        <minimum_guarantee>
                            <amount>{MG_AMOUNT_OR_BLANK}</amount>
                            <recoupment_terms>{HOW_MG_IS_RECOUPED}</recoupment_terms>
                        </minimum_guarantee>
                        <residuals_royalties>
                            <structure>{RESIDUAL_OR_ROYALTY_STRUCTURE}</structure>
                            <guild_reference>{CBA_OR_GUILD_REFERENCE}</guild_reference>
                        </residuals_royalties>
                        <reporting>
                            <frequency>{REPORTING_FREQUENCY}</frequency>
                            <deadline>{DAYS_AFTER_PERIOD_END}</deadline>
                            <audit_rights>{AUDIT_PROVISION_DETAILS}</audit_rights>
                        </reporting>
                    </financial_terms>

                    <term_and_termination>
                        <initial_term>
                            <duration>{TERM_LENGTH_OR_BLANK}</duration>
                            <commencement>{WHEN_TERM_BEGINS}</commencement>
                        </initial_term>
                        <renewal>
                            <mechanism>{RENEWAL_TERMS}</mechanism>
                            <notice_period>{NOTICE_REQUIRED}</notice_period>
                        </renewal>
                        <termination_triggers>
                            <trigger>{EACH_TERMINATION_TRIGGER}</trigger>
                        </termination_triggers>
                        <cure_period>{CURE_PERIOD_TERMS}</cure_period>
                        <post_termination>
                            <obligation>{EACH_POST_TERMINATION_OBLIGATION}</obligation>
                        </post_termination>
                        <reversion_of_rights>{REVERSION_TERMS}</reversion_of_rights>
                        <survival>{SECTIONS_THAT_SURVIVE}</survival>
                    </term_and_termination>

                    <legal_protections>
                        <representations_warranties>
                            <party_warranties party="{PARTY_NAME}">
                                <warranty>{EACH_WARRANTY}</warranty>
                            </party_warranties>
                        </representations_warranties>
                        <indemnification>
                            <type>{MUTUAL|ONE_SIDED}</type>
                            <scope>{INDEMNIFICATION_SCOPE}</scope>
                        </indemnification>
                        <governing_law>{GOVERNING_LAW_JURISDICTION}</governing_law>
                        <dispute_resolution>{ARBITRATION_MEDIATION_OR_LITIGATION}</dispute_resolution>
                        <force_majeure>{FORCE_MAJEURE_PROVISION}</force_majeure>
                    </legal_protections>

                    <signature_blocks>
                        <signature>
                            <party>{PARTY_NAME}</party>
                            <signatory_title>{AUTHORIZED_SIGNATORY_TITLE}</signatory_title>
                            <date_field>{DATE_OR_BLANK}</date_field>
                        </signature>
                    </signature_blocks>

                    <extraction_notes>
                        <unfilled_terms>
                            <unfilled_term>{EACH_BLANK_FIELD_WITH_SECTION_REF}</unfilled_term>
                        </unfilled_terms>
                        <truncated_text>
                            <truncation>{TEXT_CUT_OFF_AT_PAGE_BOUNDARIES}</truncation>
                        </truncated_text>
                    </extraction_notes>
                </element>
            </elements>
        </specialized>

    </response>
</response_format>
