<!-- You must respond using the format within the <response_format/> xml tags. -->
<!-- BADGERS Schema v1.0 — Part 1 (envelope) + Part 2 (common_spine) + layout -->

<response_format>
    <response analyzer="layout"
             schema_version="1.0"
             page="{PAGE_NUMBER}"
             session_id="{SESSION_ID}">

        <metadata>
            <source_image>{S3_URI_OR_PATH_TO_PAGE_IMAGE}</source_image>
            <analyzer_name>layout</analyzer_name>
            <timestamp>{ISO_8601_TIMESTAMP}</timestamp>
            <page_number>{PAGE_NUMBER_VISIBLE_ON_PAGE_OR_INFERRED}</page_number>
            <examples_count>{NUMBER_OF_EXAMPLE_IMAGES_YOU_WERE_GIVEN}</examples_count>
            <element_count>{NUMBER_OF_LAYOUT_ZONES_DETECTED}</element_count>
            <confidence>{high|medium|low}</confidence>
        </metadata>

        <common_spine element_count="{NUMBER_OF_TEXT_ELEMENTS}">
            <!-- Layout analyzer sees all text — extract in reading order -->
            <element id="elem_001" tag="H1" order="1" page="{PAGE}">
                <text>{HEADING_TEXT_IF_VISIBLE}</text>
            </element>
            <element id="elem_002" tag="P" order="2" page="{PAGE}">
                <text>{BODY_TEXT_IF_VISIBLE}</text>
            </element>
            <!-- Include ALL visible text in reading order -->
        </common_spine>

        <topical_analysis>{TOPICS_IDENTIFIED_IN_CONTENT}</topical_analysis>

        <specialized type="layout">
            <document_info>
                <document_type>{DOCUMENT_TYPE (e.g., book, magazine, research paper, periodical, newspaper)}</document_type>
                <orientation>{ORIENTATION (portrait/landscape)}</orientation>
                <language>{DOCUMENT_LANGUAGE}</language>
                <additional_languages>{ADDITIONAL_LANGUAGES_IN_DOCUMENT}</additional_languages>
                <writing_direction>{PRIMARY_WRITING_DIRECTION (left-to-right/right-to-left)}</writing_direction>
            </document_info>
            <overall_layout>
                <grid_system>{DESCRIPTION_OF_GRID_SYSTEM_USED}</grid_system>
                <column_structure>{NUMBER_OF_COLUMNS_AND_ARRANGEMENT}</column_structure>
                <visual_hierarchy>{DESCRIPTION_OF_VISUAL_HIERARCHY}</visual_hierarchy>
                <white_space_usage>{DESCRIPTION_OF_WHITE_SPACE_USAGE}</white_space_usage>
                <color_scheme>{DESCRIPTION_OF_COLOR_USAGE}</color_scheme>
                <overall_balance>{ASSESSMENT_OF_LAYOUT_BALANCE}</overall_balance>
            </overall_layout>
            <elements>
                <element type="layout_zone">
                    <zone_type>{ZONE TYPE (e.g., header, body, sidebar, footer, image, table)}</zone_type>
                    <position>{POSITION ON PAGE}</position>
                    <dimensions>{APPROXIMATE_SIZE}</dimensions>
                    <content_description>{WHAT_IS_IN_THIS_ZONE}</content_description>
                    <visual_weight>{HIGH/MEDIUM/LOW}</visual_weight>
                </element>
            </elements>
        </specialized>

    </response>
</response_format>
