<!-- You must respond using the format within the <response_format/> xml tags. -->
<!-- BADGERS Schema v1.0 — Part 1 (envelope) + Part 2 (common_spine) + Part 10 (remediation) -->

<response_format>
    <response analyzer="remediation"
             schema_version="1.0"
             page="{PAGE_NUMBER}"
             session_id="{SESSION_ID}">

        <metadata>
            <source_image>{S3_URI_OR_PATH_TO_PAGE_IMAGE}</source_image>
            <analyzer_name>remediation</analyzer_name>
            <timestamp>{ISO_8601_TIMESTAMP}</timestamp>
            <page_number>{PAGE_NUMBER_VISIBLE_ON_PAGE_OR_INFERRED}</page_number>
            <examples_count>{NUMBER_OF_EXAMPLE_IMAGES_YOU_WERE_GIVEN}</examples_count>
            <element_count>{NUMBER_OF_ELEMENTS_DETECTED}</element_count>
            <confidence>{high|medium|low}</confidence>
        </metadata>

        <!--
        ============================================================
        COMMON SPINE — extract ALL visible text/content in reading order.
        This provides the semantic text that will be tagged in the PDF.
        ============================================================
        -->
        <common_spine element_count="{NUMBER_OF_TEXT_ELEMENTS}">
            <!-- Page artifacts (headers/footers/page numbers) -->
            <element id="elem_001" tag="Artifact" order="1" page="{PAGE}">
                <text>{PAGE_HEADER_OR_FOOTER_TEXT}</text>
            </element>

            <!-- Document title -->
            <element id="elem_002" tag="H1" order="2" page="{PAGE}">
                <text>{DOCUMENT_TITLE}</text>
            </element>

            <!-- Section headings -->
            <element id="elem_003" tag="H2" order="3" page="{PAGE}">
                <text>{SECTION_HEADING}</text>
            </element>

            <element id="elem_004" tag="H3" order="4" page="{PAGE}">
                <text>{SUBSECTION_HEADING}</text>
            </element>

            <!-- Body paragraphs -->
            <element id="elem_005" tag="P" order="5" page="{PAGE}">
                <text>{PARAGRAPH_TEXT}</text>
            </element>

            <!-- Figures -->
            <element id="elem_006" tag="Figure" order="6" page="{PAGE}">
                <alt_text>{ACCESSIBILITY_DESCRIPTION_OF_VISUAL_CONTENT}</alt_text>
                <caption>{CAPTION_IF_ANY}</caption>
            </element>

            <!-- Captions -->
            <element id="elem_007" tag="Caption" order="7" page="{PAGE}">
                <text>{CAPTION_TEXT}</text>
            </element>

            <!-- Tables -->
            <element id="elem_008" tag="Table" order="8" page="{PAGE}">
                <text>{ALL_TABLE_CONTENT_AS_READABLE_TEXT}</text>
                <caption>{TABLE_CAPTION_IF_ANY}</caption>
            </element>

            <!-- Lists -->
            <element id="elem_009" tag="L" order="9" page="{PAGE}">
                <text>{ALL_LIST_ITEMS_AS_TEXT}</text>
            </element>

            <!-- Include ALL text you can see, in reading order -->
        </common_spine>

        <topical_analysis>{TOPICS_IDENTIFIED_IN_CONTENT}</topical_analysis>

        <!--
        ============================================================
        SPECIALIZED — PDF/UA remediation tagging with grid-based
        bounding box coordinates for precise PDF tagging.
        ============================================================
        -->
        <specialized type="remediation">

            <!-- Chain-of-thought analysis for boundary tracing -->
            <analysis>
                <page_overview>{DESCRIPTION_OF_OVERALL_PAGE_LAYOUT: single/multi-column, major sections, headers/footers/sidebars, approximate element count}</page_overview>
                <element_inventory>{LIST_ALL_ELEMENTS_IN_READING_ORDER: "1. H1 - Document title at top center", "2. P - Introductory paragraph below title", etc.}</element_inventory>
                <boundary_tracing>{FOR_EACH_SIGNIFICANT_ELEMENT_TRACE_BOUNDARIES: TOP/BOTTOM/LEFT/RIGHT edges mapped to grid coordinates}</boundary_tracing>
                <coordinate_assignment>{STATE_TOP_LEFT_AND_BOTTOM_RIGHT_FOR_EACH_ELEMENT}</coordinate_assignment>
                <validation_checks>{VERIFY_COORDINATES: no inappropriate overlaps, logical reading order, proportions match visual estimates, correct heading levels}</validation_checks>
            </analysis>

            <!-- Grid system: 36x36 cell overlay (columns A-AJ, rows 1-36) -->
            <grid_system>
                <columns>36</columns>
                <rows>36</rows>
                <description>Page is divided into a 36x36 grid. Columns labeled A through AJ (left to right), rows numbered 1 through 36 (top to bottom). Each cell represents approximately 2.8% of page width/height.</description>
            </grid_system>

            <!-- PDF/UA element type reference -->
            <element_types>
                <type name="Document">Root element containing entire document</type>
                <type name="H1">Top-level heading (document title)</type>
                <type name="H2">Major section heading</type>
                <type name="H3">Subsection heading</type>
                <type name="H4">Sub-subsection heading</type>
                <type name="H5">Lower-level heading</type>
                <type name="H6">Lowest-level heading</type>
                <type name="P">Paragraph of body text</type>
                <type name="Figure">Image, chart, diagram, or visual element</type>
                <type name="Caption">Caption text for a figure or table</type>
                <type name="Table">Tabular data structure</type>
                <type name="L">List container</type>
                <type name="LI">List item</type>
                <type name="Lbl">List item label (bullet/number)</type>
                <type name="LBody">List item body content</type>
                <type name="BibEntry">Bibliographic entry/citation</type>
                <type name="Quote">Block quotation</type>
                <type name="Note">Footnote or endnote</type>
                <type name="Reference">Reference marker linking to a note</type>
                <type name="Code">Code block or inline code</type>
                <type name="Formula">Mathematical formula</type>
                <type name="Link">Hyperlink</type>
                <type name="Artifact">Non-content element (page numbers, decorative elements, headers/footers)</type>
            </element_types>

            <!-- Confidence levels -->
            <confidence_levels>
                <level value="high">Element is clearly visible, boundaries are unambiguous, type is certain</level>
                <level value="medium">Element is identifiable but some boundaries or classification is unclear</level>
                <level value="low">Element presence or boundaries are uncertain</level>
            </confidence_levels>

            <!-- If element_count is 0, omit <elements> section entirely -->
            <elements>
                <element type="pdf_ua_element">
                    <type>{PDF_UA_ELEMENT_TYPE: H1|H2|H3|P|Figure|Table|L|Artifact|etc}</type>
                    <content>
                        <description>{TEXT_CONTENT_OR_DESCRIPTION: first 200 chars for long content}</description>
                    </content>
                    <grid_position>
                        <top_left>{CELL_AT_UPPER_LEFT_CORNER: e.g., B2}</top_left>
                        <bottom_right>{CELL_AT_LOWER_RIGHT_CORNER: e.g., AE5}</bottom_right>
                    </grid_position>
                    <confidence>{high|medium|low}</confidence>
                    <alt_text>{ALTERNATIVE_TEXT_FOR_FIGURES: required for all Figure type elements}</alt_text>
                    <parent_order>{ORDER_NUMBER_OF_PARENT_ELEMENT: for captions/nested items}</parent_order>
                    <heading_level>{1-6 for heading elements, null for others}</heading_level>
                    <is_artifact>{true|false: true for decorative/non-content elements}</is_artifact>
                </element>
            </elements>

            <!-- Example element for reference -->
            <example>
                <element type="pdf_ua_element">
                    <type>H1</type>
                    <content>
                        <description>Annual Report 2024</description>
                    </content>
                    <grid_position>
                        <top_left>E3</top_left>
                        <bottom_right>AB4</bottom_right>
                    </grid_position>
                    <confidence>high</confidence>
                    <heading_level>1</heading_level>
                </element>
            </example>

        </specialized>

    </response>
</response_format>
