<!-- You must respond using the format within the <response_format/> xml tags. -->
<!-- BADGERS Schema v1.0 — Part 1 (envelope) + Part 2 (common_spine) + classification -->

<response_format>
    <response analyzer="classification"
             schema_version="1.0"
             page="{PAGE_NUMBER}"
             session_id="{SESSION_ID}">

        <metadata>
            <source_image>{S3_URI_OR_PATH_TO_PAGE_IMAGE}</source_image>
            <analyzer_name>classification</analyzer_name>
            <timestamp>{ISO_8601_TIMESTAMP}</timestamp>
            <page_number>{PAGE_NUMBER_VISIBLE_ON_PAGE_OR_INFERRED}</page_number>
            <examples_count>{NUMBER_OF_EXAMPLE_IMAGES_YOU_WERE_GIVEN}</examples_count>
            <element_count>0</element_count>
            <confidence>{high|medium|low}</confidence>
            <image_quality>{good|fair|poor}</image_quality>
        </metadata>

        <!--
        ============================================================
        COMMON SPINE — extract prominent text visible on the page
        that informed the classification decision (titles, headings, etc.)
        ============================================================
        -->
        <common_spine element_count="{NUMBER_OF_TEXT_ELEMENTS}">
            <!-- Key text elements that helped identify content type -->
            <element id="elem_001" tag="H1" order="1" page="{PAGE}">
                <text>{PROMINENT_TITLE_OR_HEADING}</text>
            </element>

            <element id="elem_002" tag="P" order="2" page="{PAGE}">
                <text>{KEY_TEXT_SNIPPET_THAT_HELPED_CLASSIFICATION}</text>
            </element>

            <!-- Include prominent text that informed classification -->
        </common_spine>

        <topical_analysis>{TOPICS_IDENTIFIED_IN_CONTENT}</topical_analysis>

        <!--
        ============================================================
        SPECIALIZED — page content classification and quality assessment.
        This guides downstream analyzer selection.
        ============================================================
        -->
        <specialized type="classification">

            <content_description>{COMPLETE_DESCRIPTION_OF_PAGE_CONTENT: Write in full sentences describing all content, location, and notable characteristics. Be specific and thorough.}</content_description>

            <quality_assessment>
                <image_quality>{good|fair|poor}</image_quality>
                <quality_notes>{ANY_ISSUES_AFFECTING_IMAGE: blur, skew, artifacts - null if none}</quality_notes>
                <enhancement_recommended>{true|false}</enhancement_recommended>
                <enhancement_reason>{REASON_FOR_ENHANCEMENT: handwritten_annotations|degraded_scan|watermarked_security_paper|historical_manuscript|null if not recommended}</enhancement_reason>
            </quality_assessment>

            <!-- Classification examples for common page types -->
            <classification_examples>
                <example type="research_paper_title">
                    <description>Title page for academic research paper with prominent title at top, author names with institutional affiliations, abstract section, keywords at bottom, DOI and publication date in footer.</description>
                </example>
                <example type="mixed_content">
                    <description>Page with multiple content types: upper half contains data table with clear headers and numerical data; lower half contains flowchart diagram showing process flow with boxes and arrows; handwritten annotations in margins.</description>
                </example>
                <example type="poor_quality">
                    <description>Page with text content but blurry/low resolution image quality making text partially illegible. Some skew detected.</description>
                </example>
                <example type="blank_page">
                    <description>Nearly blank page with only page number in footer. Empty white space. Appears to be intentional separator or blank page.</description>
                </example>
                <example type="historical_manuscript">
                    <description>Historical manuscript page with handwritten cursive script. Visible yellowing and age-related discoloration. Faded ink in several areas. Margin notes in different hand. 18th or 19th century based on writing style.</description>
                </example>
                <example type="watermarked_security">
                    <description>Official document on blue security paper with repeating watermark text tiled across page, institutional seal overlapping content, light blue tinted background. Foreground contains structured data in tabular format.</description>
                </example>
            </classification_examples>

        </specialized>

    </response>
</response_format>