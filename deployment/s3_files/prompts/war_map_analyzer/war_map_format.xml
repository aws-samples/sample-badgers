<!-- You must respond using the format within the <response_format/> xml tags. -->
<!-- SKIP THE PREAMBLE - NO introductory text like "Here is my analysis..." -->
<!-- BADGERS MASTER SCHEMA v1.0 — Common Envelope + Spine + Specialized -->

<response_format>
    <response analyzer="war_map"
             schema_version="1.0"
             page="{PAGE_NUMBER}"
             session_id="{SESSION_ID}">

        <metadata>
            <source_image>{S3_URI_OR_PATH_TO_PAGE_IMAGE}</source_image>
            <analyzer_name>war_map</analyzer_name>
            <analyzer_version>{ANALYZER_VERSION}</analyzer_version>
            <timestamp>{ISO_8601_TIMESTAMP}</timestamp>
            <page_number>{PAGE_NUMBER_VISIBLE_ON_PAGE_OR_INFERRED}</page_number>
            <image_quality>{good|fair|poor}</image_quality>
            <enhancement_applied>{true|false}</enhancement_applied>
            <enhancement_source>{S3_URI_OF_ENHANCED_IMAGE_IF_APPLIED}</enhancement_source>
            <confidence>{overall_confidence: high|medium|low}</confidence>
            <examples_count>{NUMBER_OF_EXAMPLE_IMAGES_YOU_WERE_GIVEN}</examples_count>
            <element_count>{NUMBER_OF_WAR_MAPS_DETECTED}</element_count>
        </metadata>

        <!-- Common spine: ALL visible text on the war map page in reading order -->
        <!-- Map titles, place names, legend text, annotations, captions, etc. -->
        <!-- The map itself is a Figure element with alt_text -->
        <common_spine element_count="{NUMBER_OF_TEXT_ELEMENTS}">

            <!-- Map title -->
            <element id="{elem_XXX}"
                     tag="{H1|H2|Caption}"
                     order="{READING_ORDER_INTEGER}"
                     page="{PAGE_NUMBER}">
                <text>{MAP_TITLE_TEXT}</text>
            </element>

            <!-- The war map as a Figure -->
            <element id="{elem_XXX}"
                     tag="Figure"
                     order="{READING_ORDER_INTEGER}"
                     page="{PAGE_NUMBER}">
                <alt_text>{ACCESSIBILITY_DESCRIPTION: overall situation depicted, key forces, terrain, and tactical significance}</alt_text>
                <caption>{VISIBLE_CAPTION_TEXT_IF_ANY}</caption>
            </element>

            <!-- Surrounding text (paragraphs describing the map, source attribution, etc.) -->
            <element id="{elem_XXX}"
                     tag="{P|Caption|Note|Artifact}"
                     order="{READING_ORDER_INTEGER}"
                     page="{PAGE_NUMBER}">
                <text>{FULL_VERBATIM_TEXT}</text>
            </element>

        </common_spine>

        <topical_analysis>{COMMA_SEPARATED_TOPICS_IDENTIFIED_IN_CONTENT}</topical_analysis>

        <!-- Specialized: war map extraction (existing format preserved) -->
        <!-- If element_count is 0, omit <elements> section entirely -->
        <!-- Include one <element> per war map found -->
        <specialized type="war_map">
            <elements>
                <element type="war_map">
                    <type>War Map</type>
                    <summary>
                        <title>{MAP_TITLE_IF_VISIBLE}</title>
                        <date>{DATE_ON_MAP_OR_ESTIMATED_PERIOD}</date>
                        <scale>{SCALE_IF_INDICATED}</scale>
                        <orientation>{NORTH_ARROW_DIRECTION_OR_ASSUMED}</orientation>
                        <source>{AUTHOR_PUBLISHER_OR_SOURCE_IF_VISIBLE}</source>
                    </summary>
                    <content>
                        <historical_context>
                            <conflict>{IDENTIFIED_WAR_OR_CONFLICT}</conflict>
                            <battle_campaign>{SPECIFIC_BATTLE_OR_CAMPAIGN}</battle_campaign>
                            <approximate_date>{WHEN_THE_DEPICTED_ACTION_OCCURRED}</approximate_date>
                        </historical_context>

                        <legend>
                            <symbol_definition>
                                <symbol>{VISUAL_DESCRIPTION_OF_SYMBOL}</symbol>
                                <meaning>{WHAT_IT_REPRESENTS}</meaning>
                            </symbol_definition>
                        </legend>

                        <military_forces>
                            <force affiliation="{SIDE_NAME}">
                                <unit>
                                    <designation>{UNIT_NAME_OR_NUMBER}</designation>
                                    <type>{INFANTRY/CAVALRY/ARTILLERY/ARMOR/ETC}</type>
                                    <position>{LOCATION_ON_MAP}</position>
                                    <symbol_used>{DESCRIPTION_OF_SYMBOL}</symbol_used>
                                </unit>
                            </force>
                        </military_forces>

                        <movements>
                            <movement>
                                <type>{ATTACK/RETREAT/FLANKING/REINFORCEMENT/ETC}</type>
                                <direction>{FROM_WHERE_TO_WHERE}</direction>
                                <associated_unit>{UNIT_IF_IDENTIFIABLE}</associated_unit>
                                <visual_indicator>{ARROW_TYPE_COLOR_STYLE}</visual_indicator>
                                <temporal_phase>{PHASE_OR_TIME_IF_INDICATED}</temporal_phase>
                            </movement>
                        </movements>

                        <defensive_elements>
                            <fortification>
                                <type>{FORT/TRENCH/BUNKER/DEFENSIVE_LINE/ETC}</type>
                                <location>{WHERE_ON_MAP}</location>
                                <description>{DETAILED_DESCRIPTION}</description>
                            </fortification>
                        </defensive_elements>

                        <terrain>
                            <feature>
                                <type>{RIVER/HILL/FOREST/ROAD/BRIDGE/SETTLEMENT/ETC}</type>
                                <n>{NAME_IF_LABELED}</n>
                                <location>{WHERE_ON_MAP}</location>
                                <tactical_significance>{WHY_IT_MATTERS_MILITARILY}</tactical_significance>
                            </feature>
                        </terrain>

                        <place_names>
                            <place>
                                <n>{EXACT_TEXT}</n>
                                <type>{CITY/TOWN/RIVER/REGION/ETC}</type>
                                <location>{WHERE_ON_MAP}</location>
                            </place>
                        </place_names>

                        <battle_phases>
                            <phase>
                                <sequence>{PHASE_NUMBER_OR_ORDER}</sequence>
                                <description>{WHAT_HAPPENED_IN_THIS_PHASE}</description>
                                <time_indicator>{DATE_OR_TIME_IF_SHOWN}</time_indicator>
                            </phase>
                        </battle_phases>

                        <logistics>
                            <element>
                                <type>{SUPPLY_ROUTE/DEPOT/COMMUNICATION_LINE/ETC}</type>
                                <location>{WHERE_ON_MAP}</location>
                                <description>{DETAILS}</description>
                            </element>
                        </logistics>

                        <annotations>
                            <annotation>
                                <text>{EXACT_TEXT_OF_ANNOTATION}</text>
                                <location>{WHERE_ON_MAP}</location>
                                <interpretation>{WHAT_IT_MEANS}</interpretation>
                            </annotation>
                        </annotations>

                        <color_coding>
                            <color>
                                <color_name>{COLOR}</color_name>
                                <apparent_meaning>{WHAT_IT_REPRESENTS}</apparent_meaning>
                                <elements_using_color>{WHAT_USES_THIS_COLOR}</elements_using_color>
                            </color>
                        </color_coding>

                        <tactical_summary>
                            <situation>{OVERALL_MILITARY_SITUATION_DEPICTED}</situation>
                            <key_features>{MOST_IMPORTANT_TACTICAL_ELEMENTS}</key_features>
                            <apparent_objective>{WHAT_THE_MAP_APPEARS_TO_SHOW}</apparent_objective>
                        </tactical_summary>
                    </content>
                </element>
            </elements>
        </specialized>

    </response>
</response_format>
