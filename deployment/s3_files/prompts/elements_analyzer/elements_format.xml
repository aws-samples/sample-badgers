<!-- You must respond using the format within the <response_format/> xml tags. -->
<!-- BADGERS Schema v1.0 — Part 1 (envelope) + Part 2 (common_spine) + Part 5 (elements) -->

<response_format>
    <response analyzer="elements"
             schema_version="1.0"
             page="{PAGE_NUMBER}"
             session_id="{SESSION_ID}">

        <metadata>
            <source_image>{S3_URI_OR_PATH_TO_PAGE_IMAGE}</source_image>
            <analyzer_name>elements</analyzer_name>
            <timestamp>{ISO_8601_TIMESTAMP}</timestamp>
            <page_number>{PAGE_NUMBER_VISIBLE_ON_PAGE_OR_INFERRED}</page_number>
            <examples_count>{NUMBER_OF_EXAMPLE_IMAGES_YOU_WERE_GIVEN}</examples_count>
            <element_count>{NUMBER_OF_ELEMENTS_DETECTED}</element_count>
            <confidence>{high|medium|low}</confidence>
        </metadata>

        <!--
        ============================================================
        COMMON SPINE — extract ALL visible text/content in reading order.
        This is the primary text source for the correlator.
        ============================================================
        -->
        <common_spine element_count="{NUMBER_OF_TEXT_ELEMENTS}">
            <!-- Headings -->
            <element id="elem_001" tag="H1" order="1" page="{PAGE}">
                <text>{FULL_HEADING_TEXT}</text>
            </element>

            <!-- Paragraphs with full verbatim text -->
            <element id="elem_002" tag="P" order="2" page="{PAGE}">
                <text>{FULL_VERBATIM_PARAGRAPH_TEXT}</text>
            </element>

            <!-- Figures with accessibility descriptions -->
            <element id="elem_003" tag="Figure" order="3" page="{PAGE}">
                <alt_text>{ACCESSIBILITY_DESCRIPTION_OF_VISUAL_CONTENT}</alt_text>
                <caption>{CAPTION_TEXT_IF_ANY}</caption>
            </element>

            <!-- Captions -->
            <element id="elem_004" tag="Caption" order="4" page="{PAGE}">
                <text>{CAPTION_TEXT}</text>
            </element>

            <!-- Lists -->
            <element id="elem_005" tag="L" order="5" page="{PAGE}">
                <text>{ALL_LIST_ITEMS_AS_TEXT}</text>
            </element>

            <!-- Tables -->
            <element id="elem_006" tag="Table" order="6" page="{PAGE}">
                <text>{ALL_TABLE_CONTENT_AS_READABLE_TEXT}</text>
                <caption>{TABLE_CAPTION_IF_ANY}</caption>
            </element>

            <!-- Citations -->
            <element id="elem_007" tag="BibEntry" order="7" page="{PAGE}">
                <text>{FULL_CITATION_TEXT}</text>
            </element>

            <!-- Include ALL text you can see, in reading order -->
        </common_spine>

        <topical_analysis>{TOPICS_IDENTIFIED_IN_CONTENT}</topical_analysis>

        <!--
        ============================================================
        SPECIALIZED — detailed structural analysis of document elements.
        Preserves hierarchical levels, sub-types, and inline content.
        ============================================================
        -->
        <specialized type="document_elements">
            <!-- Reference for citation format styles -->
            <format_styles>
                <style name="APA">American Psychological Association style, commonly used in social sciences.</style>
                <style name="MLA">Modern Language Association style, often used in humanities.</style>
                <style name="Chicago">Chicago Manual of Style, used in various disciplines, especially in historical research.</style>
                <style name="Harvard">Harvard referencing style, commonly used in universities and scientific publications.</style>
                <style name="IEEE">Institute of Electrical and Electronics Engineers style, used in technical fields.</style>
                <style name="Vancouver">Vancouver system, commonly used in medical and scientific papers.</style>
            </format_styles>

            <!-- If element_count is 0, omit <elements> section entirely -->
            <elements>
                <element type="document_element">
                    <type>{ELEMENT_TYPE: heading|paragraph|citation|list|table|figure|footnote|section}</type>
                    <sub_type>{SUB_TYPE_IF_APPLICABLE: e.g., ordered_list, unordered_list, definition_list}</sub_type>
                    <hierarchical_level>{LEVEL_IN_DOCUMENT_STRUCTURE: 1=title, 2=major_section, 3=subsection, 4=sub-subsection}</hierarchical_level>
                    <content>
                        <description>{DESCRIPTION_OF_ELEMENT_PURPOSE_AND_ROLE}</description>
                        <citation_style>{IDENTIFIED_STYLE: APA|MLA|Chicago|Harvard|IEEE|Vancouver}</citation_style>

                        <!-- Include inline_elements ONLY if the element contains formulas, references, links, or semantic spans -->
                        <inline_elements>
                            <inline type="{formula|reference|link|span}">
                                <text>{THE_INLINE_TEXT}</text>
                            </inline>
                            <!-- One <inline> per inline element found within the content -->
                        </inline_elements>

                        <!-- Include list_structure ONLY for list elements -->
                        <list_structure list_type="{ordered|unordered|definition}">
                            <item level="{NESTING_DEPTH: 1=top, 2=nested}" label="{BULLET_OR_NUMBER}">
                                <text>{FULL_TEXT_OF_LIST_ITEM}</text>
                            </item>
                        </list_structure>

                        <!-- Include table_structure ONLY for table elements -->
                        <table_structure>
                            <header_row>
                                <cell scope="{column|row}">{HEADER_TEXT}</cell>
                            </header_row>
                            <data_row>
                                <cell>{CELL_TEXT}</cell>
                            </data_row>
                        </table_structure>
                    </content>
                    <context>{RELATIONSHIP_TO_SURROUNDING_ELEMENTS_AND_SECTION_MEMBERSHIP}</context>
                </element>
            </elements>
        </specialized>

    </response>
</response_format>
